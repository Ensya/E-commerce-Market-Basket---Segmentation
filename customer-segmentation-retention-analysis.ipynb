  {
   "cell_type": "code",
   "execution_count": 74,
   "id": "42f112d4",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-01-29T05:49:27.406544Z",
     "iopub.status.busy": "2026-01-29T05:49:27.406117Z",
     "iopub.status.idle": "2026-01-29T05:49:27.427990Z",
     "shell.execute_reply": "2026-01-29T05:49:27.426945Z"
    },
    "papermill": {
